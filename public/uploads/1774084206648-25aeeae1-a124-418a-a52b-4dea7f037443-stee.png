<meta name="twitter:description" content="Ikona Mody – Supreme Burberry Box Logo Tee BlackSupreme Burberry Box Logo Tee Black to połączenie dwóch ikonicznych marek w jednym. Koszulka, która stanowi doskonałą mieszankę klasycznego stylu Supreme i eleganckiego wzornictwa Burberry. Czarne tło T-shirtu Supreme podkreśla wyjątkowe, charakterystyczne logo Burberry, "><script defer>
  function swymCallbackFn(swat){
    // your API calls go here
    document.addEventListener("swym:collections-loaded", function(){
      swat.initializeActionButtons("body");
    })
  }
  if(!window.SwymCallbacks){
    window.SwymCallbacks = [];
  }
  window.SwymCallbacks.push(swymCallbackFn);


document.addEventListener("DOMContentLoaded", function () {
  const swymBtn = document.querySelector(".swym-add-to-wishlist-view-product");

  if (!swymBtn) return;

  let eventTriggered = false;

  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (
        mutation.attributeName === "class" &&
        swymBtn.classList.contains("swym-loading") &&
        !eventTriggered
      ) {
        eventTriggered = true;

     setTimeout(() => {
  document.dispatchEvent(new CustomEvent("swym:collections-loaded"));
}, "4000");
      }
    });
  });

  observer.observe(swymBtn, {
    attributes: true,
    attributeFilter: ["class"]
  });
});
</script>
